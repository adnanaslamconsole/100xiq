{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "installCommand": "npm ci",
  "framework": "vite",
  "regions": ["iad1"],
  "routes": [
    {
      "src": "/((?!assets/|og/|favicon\\.svg$).*)",
      "dest": "/api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/server/**"
    }
  }
}
